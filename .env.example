# SleepWise Automation Agent - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================
# Get your bot token from @BotFather on Telegram
# 1. Message @BotFather with /newbot
# 2. Follow the prompts to create your bot
# 3. Copy the token provided
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get your chat ID from @userinfobot or @getidsbot on Telegram
# For a channel, use the channel ID (starts with -100)
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# PINTEREST API CONFIGURATION
# =============================================================================
# Get your Pinterest access token from the Pinterest Developer Portal
# 1. Go to https://developers.pinterest.com/
# 2. Create a new app
# 3. Generate an access token with these scopes:
#    - boards:read
#    - boards:write
#    - pins:read
#    - pins:write
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token_here

# =============================================================================
# ANTHROPIC (CLAUDE) API CONFIGURATION
# =============================================================================
# Get your API key from https://console.anthropic.com/
# 1. Create an account at console.anthropic.com
# 2. Go to API Keys section
# 3. Create a new API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
# Set to 'true' when running in GitHub Actions (automatically set by workflow)
# GITHUB_ACTIONS=false

# Override the default Claude model (optional)
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Website base URL (used for generating links)
# WEBSITE_BASE_URL=https://sleepwisereviews.com
