# =============================================================================
# SleepWise Automation Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED: TELEGRAM BOT (FREE - Notifications & Reports)
# =============================================================================
# Get your bot token from @BotFather on Telegram
# 1. Message @BotFather with /newbot
# 2. Follow the prompts to create your bot
# 3. Copy the token provided
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get your chat ID from @userinfobot or @getidsbot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# REQUIRED: ANTHROPIC (CLAUDE) API - Content Generation
# =============================================================================
# Get your API key from https://console.anthropic.com/
# Cost: ~$0.01-0.05 per article generated
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Override the default Claude model (optional)
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# AUTO-POSTING: MAKE.COM (RECOMMENDED - $9/month Core)
# =============================================================================
# Sign up: https://make.com
# Create scenario: Schedule trigger > GitHub > Instagram for Business
# Copy the webhook URL from your scenario's webhook trigger module
MAKE_WEBHOOK_BASE=https://hook.eu1.make.com/your-webhook-id
MAKE_WEBHOOK_SECRET=your_make_webhook_secret_here

# =============================================================================
# AUTO-POSTING ALTERNATIVE: BUFFER ($6/month)
# =============================================================================
# Sign up: https://buffer.com
# Get token: Settings > Apps & Extras > Access Token
# Supports: Instagram, Pinterest, Twitter/X, Facebook
BUFFER_ACCESS_TOKEN=

# =============================================================================
# DEPRECATED: N8N (no longer used)
# =============================================================================
# N8N_WEBHOOK_BASE=
# N8N_API_KEY=

# =============================================================================
# AUTO-POSTING ALTERNATIVE: ZAPIER (FREE - 100 tasks/month)
# =============================================================================
# Sign up: https://zapier.com
# Create Zap with Webhook trigger
ZAPIER_WEBHOOK_URL=

# =============================================================================
# PINTEREST API (For direct Pinterest posting)
# =============================================================================
# Get token from: https://developers.pinterest.com/
# Scopes needed: boards:read, boards:write, pins:read, pins:write
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token_here
PINTEREST_BOARD_ID=

# =============================================================================
# IMAGE HOSTING (Required for auto-posting images)
# =============================================================================
# Option 1: Cloudinary (FREE - 25GB storage)
# Sign up: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Option 2: Imgur (FREE)
# Sign up: https://api.imgur.com/oauth2/addclient
IMGUR_CLIENT_ID=
IMGUR_CLIENT_SECRET=

# =============================================================================
# AFFILIATE PROGRAMS
# =============================================================================
# Amazon Associates (Primary)
# Sign up: https://affiliate-program.amazon.com
AMAZON_AFFILIATE_TAG=sleepwise-20
AMAZON_ASSOCIATE_ID=

# ClickBank (High commissions)
# Sign up: https://www.clickbank.com
CLICKBANK_NICKNAME=
CLICKBANK_API_KEY=

# ShareASale (Premium brands)
# Sign up: https://www.shareasale.com
SHAREASALE_MERCHANT_ID=
SHAREASALE_API_TOKEN=

# Impact (Mattress brands)
# Sign up: https://impact.com
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=

# =============================================================================
# WEBSITE CONFIGURATION
# =============================================================================
WEBSITE_BASE_URL=https://hanysharaf.github.io/sleepwisereviews/
BLOGGER_URL=https://sleepwisereviews.blogspot.com

# =============================================================================
# SCHEDULING
# =============================================================================
# Timezone for scheduling (default: UTC)
TIMEZONE=America/New_York

# =============================================================================
# GITHUB ACTIONS (Auto-set when running in Actions)
# =============================================================================
# GITHUB_ACTIONS=true  # Automatically set by GitHub
